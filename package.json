{
  "name": "gopro-clips",
  "version": "0.1.0",
  "description": "Desktop app to browse GoPro SD card recordings, preview proxy footage, and export clips and snapshots",
  "main": "main/index.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.gopro.clips",
    "productName": "GoPro Clips",
    "mac": {
      "target": "dmg"
    },
    "files": [
      "dist/**/*",
      "main/**/*"
    ]
  }
}
