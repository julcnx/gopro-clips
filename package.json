{
  "name": "gopro-clips",
  "version": "0.1.0",
  "description": "Desktop app to browse GoPro SD card recordings, preview proxy footage, and export clips and snapshots",
  "author": "Julien Etienne <julien.etienne@intuiquest.com>",
  "homepage": "https://github.com/julcnx/gopro-clips",
  "repository": {
    "type": "git",
    "url": "git@github.com:julcnx/gopro-clips.git"
  },
  "license": "MIT",
  "main": "main/index.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k -n vite,electron --success command-electron \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder --mac --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.gopro.clips",
    "productName": "GoPro Clips",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "buildResources": "build"
    },
    "copyright": "Copyright © 2026 Julien Etienne",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "shortcutName": "GoPro Clips"
    },
    "files": [
      "dist/**/*",
      "main/**/*"
    ]
  }
}
